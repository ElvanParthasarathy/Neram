<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark theme matching React admin portal -->
    <style name="Theme.Neram" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">#000000</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash theme for backwards compatibility (pre-Android 12) -->
    <style name="Theme.Neram.Splash" parent="Theme.Neram" />
</resources>
